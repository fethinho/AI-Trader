",
    " payload = {\"chat_id\": chat_id, \"text\": text, \"parse_mode\": \"Markdown\", \"disable_web_page_preview\": True}
",
    " try:
",
    "  r = requests.post(url, data=payload, timeout=20)
",
    "  return r.status_code, r.text
